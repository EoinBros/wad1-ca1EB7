{{> menu id=id}}

<section class="about-section">
  <h1>{{title}}</h1>
  <div class="about-content">
    <div class="app-info">
      <table>
        <tr><td><strong>App Name</strong></td><td>{{info.appTitle}}</td></tr>
        <tr><td><strong>Version</strong></td><td>{{info.version}}</td></tr>
        <tr><td><strong>Location</strong></td><td>{{info.location}}</td></tr>
      </table>
      <h2>Created by</h2>
      <!-- custom creator card for Eoin Brosnan -->
      <div class="creator creator-large">
        <img src="/batman.jpg" alt="Eoin Brosnan" class="creator-avatar" />
        <div class="creator-details">
          <strong>Eoin Brosnan</strong><br>
          Joined in 2025<br>
          Web App Developer living in Ireland<br>
          44 contacts
        </div>
      </div>
    </div>
    <div class="map-container">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d23831.837062011702!2d-7.132796015784364!3d52.240888634871034!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4842c41310dd4131%3A0x4042f0dcf13f7cfe!2sSouth%20East%20Technological%20University%20%7C%20Waterford%20(SETU)!5e0!3m2!1sen!2sie!4v1772792198719!5m2!1sen!2sie" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>
