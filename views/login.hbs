<main class="auth-page">
  <section class="auth-card">
    <nav class="auth-menu">
      <a class="auth-brand" href="/">Clothing Store Login menu</a>
      <div class="auth-tabs">
        <a id="signup" href="/signup">Signup</a>
        <a id="login" href="/login" class="active">Login</a>
      </div>
    </nav>

    <form class="auth-form" action="/login" method="POST">
      <h1>Log-in</h1>

      {{#if error}}
        <p class="auth-error">{{error}}</p>
      {{/if}}

      <label for="email">Email</label>
      <input type="text" id="email" name="email" placeholder="email@example.com" required />

      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="Password" required />

      <button type="submit" class="btn auth-button">Login</button>
    </form>
  </section>
</main>
