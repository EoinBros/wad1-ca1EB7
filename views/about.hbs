{{> menu id="about"}}

<h1>{{title}}</h1>

<div class="ui three stackable cards">
  {{#each employee}}
  <div class="ui centered card">
    <div class="image">
      <img src="{{this.image}}" alt="{{this.name}}">
    </div>
    <div class="content">
      <a class="header">{{this.fullname}}</a>
      <div class="meta">
        <span class="date">Joined in {{this.joined}}</span>
      </div>
      <div class="description">
        {{this.name}} is a {{this.job}} living in {{this.city}}.
      </div>
    </div>
    <div class="extra content">
      <a>
        <i class="user icon"></i>
        {{this.mates}} contacts
      </a>
    </div>
  </div>
  {{/each}}
</div>

<h2>{{title}} Items</h2>
<div class="product-list">
  {{#each products}}
    <h3 class="category-heading">{{@key}}</h3>
    {{#each this}}
      <div class="product-row">
        <div class="product-details">
          <span class="product-name">{{this.name}}</span>
          <span class="product-price">{{this.price}}</span><br>
          <span class="product-desc">{{this.description}}</span>
        </div>
      </div>
    {{/each}}
  {{/each}}
</div>

