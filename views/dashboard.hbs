<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  {{> menu id=id}}
  <header>
    <h1>{{title}}</h1>
  </header>

  <main id="collections-container">
    <section class="collections-section">
      <h2>Collections</h2>
      {{#if currentUser}}
        <p class="dashboard-user">Logged in as {{currentUser.firstName}} {{currentUser.lastName}}</p>
      {{/if}}
      
      <div class="collections-grid">
        {{#each categories}}
          <div class="collection-card">
            <div class="collection-image-wrapper">
              <img src="{{this.image}}" alt="{{this.displayName}}" class="collection-image" />
            </div>
            <div class="collection-info">
              <h3 class="collection-title">{{this.displayName}}</h3>
              <p class="collection-meta">Items: {{this.itemCount}}</p>
              <p class="collection-date">Created: {{this.createdDate}}</p>
            </div>
            <div class="collection-actions">
              <a href="/category/{{this.id}}" class="btn btn-view">View Collection</a>
              <button class="btn btn-delete" onclick="deleteCategory('{{this.id}}')">Delete</button>
            </div>
          </div>
        {{/each}}
      </div>
    </section>

    <section class="add-collection-section">
      <h2>Add New Collection</h2>
      <form class="add-collection-form" onsubmit="addCategory(event)">
        <div class="form-group">
          <label for="collection-name">Collection Name:</label>
          <input 
            type="text" 
            id="collection-name" 
            name="collectionName" 
            placeholder="Enter collection name"
            required
          />
        </div>
        <div class="form-group">
          <label for="collection-image">Collection Image:</label>
          <input 
            type="file" 
            id="collection-image" 
            name="collectionImage" 
            accept="image/*"
          />
        </div>
        <button type="submit" class="btn btn-primary">Add Collection</button>
      </form>
    </section>
  </main>

  <script src="js/main.js"></script>
  <script>
    function deleteCategory(categoryId) {
      if (confirm(`Are you sure you want to delete the "${categoryId}" collection?`)) {
        fetch(`/dashboard/category/${categoryId}`, {
          method: 'DELETE'
        })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              window.location.reload();
            } else {
              alert(data.error || 'Error deleting collection');
            }
          })
          .catch(() => {
            alert('Error deleting collection');
          });
      }
    }

    function addCategory(event) {
      event.preventDefault();
      const collectionName = document.getElementById('collection-name').value;
      
      if (!collectionName.trim()) {
        alert('Please enter a collection name');
        return;
      }
      
      fetch('/dashboard/category', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ collectionName })
      })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            window.location.reload();
          } else {
            alert(data.error || 'Error adding collection');
          }
        })
        .catch(() => {
          alert('Error adding collection');
        });
    }
  </script>
</body>
</html>
