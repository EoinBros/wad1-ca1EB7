<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{title}}</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  {{> menu id=id}}
  <header>
    <h1>{{title}}</h1>
  </header>

  {{!-- quick links to each category (navigate to dedicated pages) --}}
  <nav class="category-nav">
    {{#each products}}
      <a href="/category/{{@key}}" class="category-link">{{@key}}</a>
    {{/each}}
  </nav>

  <main id="products-container">
    {{!-- iterate over each category in the products object --}}
    {{#each products}}
      <section id="{{@key}}" class="category-section">
        <h2 class="category-title">{{@key}}</h2>
        <div class="products-grid">
          {{#each this}}
            <div class="product-card">
              <img src="{{this.image}}" alt="{{this.name}}" class="product-image" />
              <h3>{{this.name}}</h3>
              <p>{{this.price}}</p>
              <p>{{this.description}}</p>
            </div>
          {{/each}}
        </div>
      </section>
    {{/each}}
  </main>



  <script src="js/main.js"></script>
</body>
</html>