<main class="auth-page">
  <section class="auth-card">
    <nav class="auth-menu">
      <a class="auth-brand" href="/">Clothing Store Signup menu</a>
      <div class="auth-tabs">
        <a id="signup" href="/signup" class="active">Signup</a>
        <a id="login" href="/login">Login</a>
      </div>
    </nav>

    <form class="auth-form" action="/signup" method="POST" enctype="multipart/form-data">
      <h1>Sign-up</h1>

      {{#if error}}
        <p class="auth-error">{{error}}</p>
      {{/if}}

      <label for="firstName">First name</label>
      <input type="text" id="firstName" name="firstName" placeholder="First name" required />

      <label for="lastName">Last name</label>
      <input type="text" id="lastName" name="lastName" placeholder="Last name" required />

      <label for="email">Email</label>
      <input type="email" id="email" name="email" placeholder="email@example.com" required />

      <label for="password">Password</label>
      <input type="password" id="password" name="password" placeholder="Password" required />

      <label for="profileImage">Profile image</label>
      <input type="file" id="profileImage" name="profileImage" accept="image/*" />

      <button type="submit" class="btn auth-button">Signup</button>
    </form>
  </section>
</main>
